server {
    listen 80;
    server_name example.com;

    root /var/www/operation_U-D-A-V;
    index index.html;

    error_page 404 /404.html;

    location = /404.html {
        internal;
    }

    location = /index.html {
        return 301 /;
    }

    location = /about {
        return 301 /about/;
    }

    location = /contact {
        return 301 /contact/;
    }

    location = /login {
        return 301 /login/;
    }

    location = /register {
        return 301 /register/;
    }

    rewrite ^/about\.html$ /about/ permanent;
    rewrite ^/contactus\.html$ /contact/ permanent;
    rewrite ^/login\.html$ /login/ permanent;
    rewrite ^/register\.html$ /register/ permanent;

    rewrite ^/post1\.html$ /blogs/some-amazing-similarities-between-people-around-the-world/ permanent;
    rewrite ^/post2\.html$ /blogs/little-known-facts-about-deer-worth-knowing/ permanent;
    rewrite ^/post3\.html$ /blogs/shape-the-import-surface-of-a-python-analytics-service-before-the-live-loop/ permanent;
    rewrite ^/post4\.html$ /blogs/keep-postgresql-lookups-cheap-while-a-vision-worker-boots-up/ permanent;
    rewrite ^/post5\.html$ /blogs/turn-yolo-detections-into-per-frame-motion-buckets-without-losing-the-thread/ permanent;
    rewrite ^/post6\.html$ /blogs/ship-live-metrics-into-postgresql-fan-them-out-and-keep-a-debug-overlay-nearby/ permanent;
    rewrite ^/post7\.html$ /blogs/sketch-a-streamlit-analytics-page-with-filters-before-the-data-arrives/ permanent;
    rewrite ^/post8\.html$ /blogs/query-recent-telemetry-and-draw-plotly-views-without-overcomplicating-the-refresh-cycle/ permanent;
    rewrite ^/post9\.html$ /blogs/switch-between-live-mode-batch-export-and-safe-shutdown-in-one-python-entry-file/ permanent;
    rewrite ^/post10\.html$ /blogs/lay-out-a-traffic-intelligence-file-before-the-first-frame-arrives/ permanent;
    rewrite ^/post11\.html$ /blogs/track-vehicles-frame-by-frame-and-paint-a-calm-overlay-in-pil/ permanent;
    rewrite ^/post12\.html$ /blogs/persist-live-detections-and-roll-them-into-an-hourly-mart/ permanent;
    rewrite ^/post13\.html$ /blogs/start-the-workers-once-and-cache-the-first-history-pull/ permanent;
    rewrite ^/post14\.html$ /blogs/filter-a-streamlit-traffic-dashboard-without-turning-the-layout-into-glue/ permanent;
    rewrite ^/post15\.html$ /blogs/validate-a-forecasting-loop-and-surface-dispatcher-warnings-without-noise/ permanent;

    rewrite ^/blogs/([^/]+)$ /blogs/$1/ permanent;

    location / {
        try_files $uri $uri/ =404;
    }
}
