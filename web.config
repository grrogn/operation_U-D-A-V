<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" path="/404.html" responseMode="File" />
    </httpErrors>
    <rewrite>
      <rules>
        <rule name="legacy-home" stopProcessing="true">
          <match url="^index\.html$" />
          <action type="Redirect" url="/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-about" stopProcessing="true">
          <match url="^about\.html$" />
          <action type="Redirect" url="/about/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-contact" stopProcessing="true">
          <match url="^contactus\.html$" />
          <action type="Redirect" url="/contact/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-login" stopProcessing="true">
          <match url="^login\.html$" />
          <action type="Redirect" url="/login/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-register" stopProcessing="true">
          <match url="^register\.html$" />
          <action type="Redirect" url="/register/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post1" stopProcessing="true">
          <match url="^post1\.html$" />
          <action type="Redirect" url="/blogs/some-amazing-similarities-between-people-around-the-world/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post2" stopProcessing="true">
          <match url="^post2\.html$" />
          <action type="Redirect" url="/blogs/little-known-facts-about-deer-worth-knowing/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post3" stopProcessing="true">
          <match url="^post3\.html$" />
          <action type="Redirect" url="/blogs/shape-the-import-surface-of-a-python-analytics-service-before-the-live-loop/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post4" stopProcessing="true">
          <match url="^post4\.html$" />
          <action type="Redirect" url="/blogs/keep-postgresql-lookups-cheap-while-a-vision-worker-boots-up/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post5" stopProcessing="true">
          <match url="^post5\.html$" />
          <action type="Redirect" url="/blogs/turn-yolo-detections-into-per-frame-motion-buckets-without-losing-the-thread/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post6" stopProcessing="true">
          <match url="^post6\.html$" />
          <action type="Redirect" url="/blogs/ship-live-metrics-into-postgresql-fan-them-out-and-keep-a-debug-overlay-nearby/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post7" stopProcessing="true">
          <match url="^post7\.html$" />
          <action type="Redirect" url="/blogs/sketch-a-streamlit-analytics-page-with-filters-before-the-data-arrives/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post8" stopProcessing="true">
          <match url="^post8\.html$" />
          <action type="Redirect" url="/blogs/query-recent-telemetry-and-draw-plotly-views-without-overcomplicating-the-refresh-cycle/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post9" stopProcessing="true">
          <match url="^post9\.html$" />
          <action type="Redirect" url="/blogs/switch-between-live-mode-batch-export-and-safe-shutdown-in-one-python-entry-file/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post10" stopProcessing="true">
          <match url="^post10\.html$" />
          <action type="Redirect" url="/blogs/lay-out-a-traffic-intelligence-file-before-the-first-frame-arrives/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post11" stopProcessing="true">
          <match url="^post11\.html$" />
          <action type="Redirect" url="/blogs/track-vehicles-frame-by-frame-and-paint-a-calm-overlay-in-pil/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post12" stopProcessing="true">
          <match url="^post12\.html$" />
          <action type="Redirect" url="/blogs/persist-live-detections-and-roll-them-into-an-hourly-mart/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post13" stopProcessing="true">
          <match url="^post13\.html$" />
          <action type="Redirect" url="/blogs/start-the-workers-once-and-cache-the-first-history-pull/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post14" stopProcessing="true">
          <match url="^post14\.html$" />
          <action type="Redirect" url="/blogs/filter-a-streamlit-traffic-dashboard-without-turning-the-layout-into-glue/" redirectType="Permanent" />
        </rule>
        <rule name="legacy-post15" stopProcessing="true">
          <match url="^post15\.html$" />
          <action type="Redirect" url="/blogs/validate-a-forecasting-loop-and-surface-dispatcher-warnings-without-noise/" redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
